{"ast":null,"code":"import { materialPage, materialCreate, materialUpdate, materialDelete } from '@/api/material';\nexport default {\n  data: () => ({\n    query: {\n      pageNum: 1,\n      pageSize: 10\n    },\n    list: [],\n    total: 0,\n    visible: false,\n    form: {}\n  }),\n  mounted() {\n    this.load();\n  },\n  methods: {\n    async load() {\n      const r = await materialPage(this.query);\n      this.list = r.data.list;\n      this.total = r.data.total;\n    },\n    open(row) {\n      this.form = row ? {\n        ...row\n      } : {\n        warnThreshold: 0\n      };\n      this.visible = true;\n    },\n    async save() {\n      if (this.form.id) await materialUpdate(this.form);else await materialCreate(this.form);\n      this.visible = false;\n      this.load();\n      this.$message.success('成功');\n    },\n    async del(r) {\n      await materialDelete(r.id);\n      this.load();\n      this.$message.success('已删除');\n    }\n  }\n};","map":{"version":3,"names":["materialPage","materialCreate","materialUpdate","materialDelete","data","query","pageNum","pageSize","list","total","visible","form","mounted","load","methods","r","open","row","warnThreshold","save","id","$message","success","del"],"sources":["src/views/inventory/tabs/MaterialTab.vue"],"sourcesContent":["<template><div>\n  <el-button type=\"primary\" size=\"mini\" @click=\"open()\">新增物资</el-button>\n  <el-table :data=\"list\" style=\"margin-top:10px\"><el-table-column prop=\"materialName\" label=\"名称\"/><el-table-column prop=\"materialType\" label=\"类型\"/><el-table-column prop=\"warnThreshold\" label=\"阈值\"/><el-table-column label=\"操作\"><template slot-scope=\"s\"><el-button size=\"mini\" @click=\"open(s.row)\">编辑</el-button><el-button size=\"mini\" type=\"danger\" @click=\"del(s.row)\">删除</el-button></template></el-table-column></el-table>\n  <el-pagination @current-change=\"p=>{query.pageNum=p;load()}\" :current-page=\"query.pageNum\" :page-size=\"query.pageSize\" layout=\"total,prev,pager,next\" :total=\"total\"/>\n  <el-dialog :visible.sync=\"visible\" title=\"物资\"><el-form :model=\"form\"><el-form-item label=\"名称\"><el-input v-model=\"form.materialName\"/></el-form-item><el-form-item label=\"类型\"><el-input v-model=\"form.materialType\"/></el-form-item><el-form-item label=\"单位\"><el-input v-model=\"form.unit\"/></el-form-item><el-form-item label=\"阈值\"><el-input-number v-model=\"form.warnThreshold\"/></el-form-item></el-form><span slot=\"footer\"><el-button @click=\"visible=false\">取消</el-button><el-button type=\"primary\" @click=\"save\">保存</el-button></span></el-dialog>\n</div></template>\n<script>\nimport { materialPage, materialCreate, materialUpdate, materialDelete } from '@/api/material'\nexport default { data:()=>({query:{pageNum:1,pageSize:10},list:[],total:0,visible:false,form:{}}), mounted(){this.load()}, methods:{async load(){const r=await materialPage(this.query); this.list=r.data.list; this.total=r.data.total}, open(row){this.form=row?{...row}:{warnThreshold:0}; this.visible=true}, async save(){if(this.form.id) await materialUpdate(this.form); else await materialCreate(this.form); this.visible=false; this.load(); this.$message.success('成功')}, async del(r){await materialDelete(r.id); this.load(); this.$message.success('已删除')}} }\n</script>\n"],"mappings":"AAOA,SAAAA,YAAA,EAAAC,cAAA,EAAAC,cAAA,EAAAC,cAAA;AACA;EAAAC,IAAA,EAAAA,CAAA;IAAAC,KAAA;MAAAC,OAAA;MAAAC,QAAA;IAAA;IAAAC,IAAA;IAAAC,KAAA;IAAAC,OAAA;IAAAC,IAAA;EAAA;EAAAC,QAAA;IAAA,KAAAC,IAAA;EAAA;EAAAC,OAAA;IAAA,MAAAD,KAAA;MAAA,MAAAE,CAAA,SAAAf,YAAA,MAAAK,KAAA;MAAA,KAAAG,IAAA,GAAAO,CAAA,CAAAX,IAAA,CAAAI,IAAA;MAAA,KAAAC,KAAA,GAAAM,CAAA,CAAAX,IAAA,CAAAK,KAAA;IAAA;IAAAO,KAAAC,GAAA;MAAA,KAAAN,IAAA,GAAAM,GAAA;QAAA,GAAAA;MAAA;QAAAC,aAAA;MAAA;MAAA,KAAAR,OAAA;IAAA;IAAA,MAAAS,KAAA;MAAA,SAAAR,IAAA,CAAAS,EAAA,QAAAlB,cAAA,MAAAS,IAAA,aAAAV,cAAA,MAAAU,IAAA;MAAA,KAAAD,OAAA;MAAA,KAAAG,IAAA;MAAA,KAAAQ,QAAA,CAAAC,OAAA;IAAA;IAAA,MAAAC,IAAAR,CAAA;MAAA,MAAAZ,cAAA,CAAAY,CAAA,CAAAK,EAAA;MAAA,KAAAP,IAAA;MAAA,KAA