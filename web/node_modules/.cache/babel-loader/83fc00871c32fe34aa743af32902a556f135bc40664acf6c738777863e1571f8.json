{"ast":null,"code":"import { alertPage, alertAck } from '@/api/alert';\nexport default {\n  data: () => ({\n    list: []\n  }),\n  mounted() {\n    this.load();\n  },\n  methods: {\n    async load() {\n      const r = await alertPage({\n        pageNum: 1,\n        pageSize: 50\n      });\n      this.list = r.data.list;\n    },\n    async ack(r) {\n      await alertAck({\n        id: r.id\n      });\n      this.load();\n      this.$message.success('已确认');\n    }\n  }\n};","map":{"version":3,"names":["alertPage","alertAck","data","list","mounted","load","methods","r","pageNum","pageSize","ack","id","$message","success"],"sources":["src/views/alert/AlertListView.vue"],"sourcesContent":["<template><div>\n  <el-table :data=\"list\"><el-table-column prop=\"alertType\" label=\"类型\"/><el-table-column prop=\"alertLevel\" label=\"级别\"/><el-table-column prop=\"status\" label=\"状态\"><template slot-scope=\"s\"><el-tag :type=\"s.row.status==='UNCONFIRMED'?'danger':'success'\">{{s.row.status}}</el-tag></template></el-table-column><el-table-column prop=\"alertMessage\" label=\"消息\"/><el-table-column label=\"操作\"><template slot-scope=\"s\"><el-button v-if=\"s.row.status==='UNCONFIRMED'\" size=\"mini\" @click=\"ack(s.row)\">确认</el-button></template></el-table-column></el-table>\n</div></template>\n<script>\nimport { alertPage, alertAck } from '@/api/alert'\nexport default { data:()=>({list:[]}), mounted(){this.load()}, methods:{async load(){const r=await alertPage({pageNum:1,pageSize:50}); this.list=r.data.list}, async ack(r){await alertAck({id:r.id}); this.load(); this.$message.success('已确认')}} }\n</script>\n"],"mappings":"AAIA,SAAAA,SAAA,EAAAC,QAAA;AACA;EAAAC,IAAA,EAAAA,CAAA;IAAAC,IAAA;EAAA;EAAAC,QAAA;IAAA,KAAAC,IAAA;EAAA;EAAAC,OAAA;IAAA,MAAAD,KAAA;MAAA,MAAAE,CAAA,SAAAP,SAAA;QAAAQ,OAAA;QAAAC,QAAA;MAAA;MAAA,KAAAN,IAAA,GAAAI,CAAA,CAAAL,IAAA,CAAAC,IAAA;IAAA;IAAA,MAAAO,IAAAH,CAAA;MAAA,MAAAN,QAAA;QAAAU,EAAA,EAAAJ,CAAA,CAAAI;MAAA;MAAA,KAAAN,IAAA;MAAA,KAAAO,QAAA,CAAAC,OAAA;IAAA;EAAA;AAAA