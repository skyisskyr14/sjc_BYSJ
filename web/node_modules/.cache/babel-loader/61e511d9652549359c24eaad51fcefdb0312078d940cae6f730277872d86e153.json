{"ast":null,"code":"import { inventoryPage, inbound, outbound } from '@/api/inventory';\nexport default {\n  data: () => ({\n    query: {\n      pageNum: 1,\n      pageSize: 10\n    },\n    list: [],\n    visible: false,\n    mode: 'in',\n    form: {\n      qty: 1\n    }\n  }),\n  mounted() {\n    this.load();\n  },\n  methods: {\n    async load() {\n      const r = await inventoryPage(this.query);\n      this.list = r.data.list;\n    },\n    open(m) {\n      this.mode = m;\n      this.visible = true;\n    },\n    async submit() {\n      if (this.mode === 'in') await inbound(this.form);else await outbound(this.form);\n      this.visible = false;\n      this.load();\n      this.$message.success('操作成功');\n    }\n  }\n};","map":{"version":3,"names":["inventoryPage","inbound","outbound","data","query","pageNum","pageSize","list","visible","mode","form","qty","mounted","load","methods","r","open","m","submit","$message","success"],"sources":["src/views/inventory/tabs/InventoryTab.vue"],"sourcesContent":["<template><div>\n  <el-button size=\"mini\" type=\"success\" @click=\"open('in')\">入库</el-button>\n  <el-button size=\"mini\" type=\"warning\" @click=\"open('out')\">出库</el-button>\n  <el-table :data=\"list\" style=\"margin-top:10px\"><el-table-column prop=\"warehouseName\" label=\"仓库\"/><el-table-column prop=\"materialName\" label=\"物资\"/><el-table-column prop=\"qtyAvailable\" label=\"可用库存\"/><el-table-column prop=\"warnThreshold\" label=\"阈值\"/></el-table>\n  <el-dialog :visible.sync=\"visible\" :title=\"mode==='in'?'入库':'出库'\"><el-form :model=\"form\"><el-form-item label=\"仓库ID\"><el-input-number v-model=\"form.warehouseId\"/></el-form-item><el-form-item label=\"物资ID\"><el-input-number v-model=\"form.materialId\"/></el-form-item><el-form-item label=\"数量\"><el-input-number v-model=\"form.qty\"/></el-form-item><el-form-item label=\"备注\"><el-input v-model=\"form.remark\"/></el-form-item></el-form><span slot=\"footer\"><el-button @click=\"visible=false\">取消</el-button><el-button type=\"primary\" @click=\"submit\">提交</el-button></span></el-dialog>\n</div></template>\n<script>\nimport { inventoryPage, inbound, outbound } from '@/api/inventory'\nexport default { data:()=>({query:{pageNum:1,pageSize:10},list:[],visible:false,mode:'in',form:{qty:1}}), mounted(){this.load()}, methods:{async load(){const r=await inventoryPage(this.query); this.list=r.data.list}, open(m){this.mode=m;this.visible=true}, async submit(){ if(this.mode==='in') await inbound(this.form); else await outbound(this.form); this.visible=false; this.load(); this.$message.success('操作成功')}} }\n</script>\n"],"mappings":"AAOA,SAAAA,aAAA,EAAAC,OAAA,EAAAC,QAAA;AACA;EAAAC,IAAA,EAAAA,CAAA;IAAAC,KAAA;MAAAC,OAAA;MAAAC,QAAA;IAAA;IAAAC,IAAA;IAAAC,OAAA;IAAAC,IAAA;IAAAC,IAAA;MAAAC,GAAA;IAAA;EAAA;EAAAC,QAAA;IAAA,KAAAC,IAAA;EAAA;EAAAC,OAAA;IAAA,MAAAD,KAAA;MAAA,MAAAE,CAAA,SAAAf,aAAA,MAAAI,KAAA;MAAA,KAAAG,IAAA,GAAAQ,CAAA,CAAAZ,IAAA,CAAAI,IAAA;IAAA;IAAAS,KAAAC,CAAA;MAAA,KAAAR,IAAA,GAAAQ,CAAA;MAAA,KAAAT,OAAA;IAAA;IAAA,MAAAU,OAAA;MAAA,SAAAT,IAAA,iBAAAR,OAAA,MAAAS,IAAA,aAAAR,QAAA,MAAAQ,IAAA;MAAA,KAAAF,OAAA;MAAA,KAAAK,IAAA;MAAA,KAAAM,QAAA,CAAAC,OAAA;IAAA;EAAA;AAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}